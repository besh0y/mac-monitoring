{
  "uid": "mac-today",
  "title": "Mac System \u2014 Today",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "tags": [
    "mac",
    "system"
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "CPU \u00b7 avg",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Average over the selected time range (follows the time picker; nulls from sleep/off are ignored).",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "maxDataPoints": 100,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 1
    },
    {
      "type": "stat",
      "title": "Memory \u00b7 avg",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Average over the selected time range (follows the time picker; nulls from sleep/off are ignored). macOS \u201cMemory Used\u201d = wired + compressed + app memory (internal \u2212 purgeable) \u00f7 total \u2014 matches Activity Monitor. \u201cactive\u201d is excluded because it includes reclaimable file cache. Raw values verified against vm_stat.",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "maxDataPoints": 100,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "100 * (node_memory_wired_bytes + node_memory_compressed_bytes + node_memory_internal_bytes - node_memory_purgeable_bytes) / node_memory_total_bytes",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Disk \u00b7 avg",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Average over the selected time range (follows the time picker; nulls from sleep/off are ignored). Used % = 1 \u2212 avail/size. Reads ~2 pp above Finder/df: on APFS, node_exporter reports free == avail and can\u2019t see the container-shared/purgeable space df excludes, so Finder\u2019s figure isn\u2019t reproducible from the metrics. Size & avail themselves match df exactly.",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "maxDataPoints": 100,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/System/Volumes/Data\"} / node_filesystem_size_bytes{mountpoint=\"/System/Volumes/Data\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Load \u00b7 avg (1m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Average over the selected time range (follows the time picker; nulls from sleep/off are ignored). Load average = the average number of threads running on or waiting for a CPU. Read it against your CPU core count: \u2248 cores = fully busy, well above = work is queueing (contention), below = spare capacity. This Mac has 10 logical CPUs, so ~10 is saturated. The graph shows 1- / 5- / 15-minute averages (short \u2192 long term).",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "maxDataPoints": 100,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 8
              },
              {
                "color": "red",
                "value": 16
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "node_load1",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "spanNulls": false
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])))",
          "legendFormat": "cpu busy",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 5
    },
